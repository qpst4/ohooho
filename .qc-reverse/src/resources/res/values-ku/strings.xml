    <string name="limited_warning">Hişyari</string>
    <string name="limited_warning_detail_1">Ev şêwaz di hin sepanan an hin rewşan de naxebite, ew şêwaz ceribandî ye ku hûn bibînin ka ew ji tinebûnê çêtir e.</string>
