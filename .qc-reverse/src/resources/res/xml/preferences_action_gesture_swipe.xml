<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" app:iconSpaceReserved="false">
    <com.quickcursor.android.preferences.DetailedListPreference
        android:entries="@array/action_gesture_swipe_direction_titles"
        android:title="@string/action_gesture_swipe_direction_title"
        android:key="swipeDirection"
        android:summary="%s"
        android:defaultValue="@string/default_action_gesture_swipe_direction"
        android:entryValues="@array/action_gesture_swipe_direction_values"
        app:entryIcons="@array/action_gesture_swipe_direction_icons"
        app:iconSpaceReserved="false"/>
    <com.quickcursor.android.preferences.DetailedListPreference
        android:entries="@array/action_gesture_swipe_distance_titles"
        android:title="@string/action_gesture_swipe_distance_title"
        android:key="swipeDistance"
        android:summary="%s"
        android:defaultValue="@string/default_action_gesture_swipe_distance"
        android:entryValues="@array/action_gesture_swipe_distance_values"
        app:iconSpaceReserved="false"/>
    <com.quickcursor.android.preferences.SeekBarDialogPreference
        android:title="@string/action_gesture_swipe_duration_title"
        app:defaultValue="@integer/default_action_gesture_swipe_duration"
        app:iconSpaceReserved="false"
        app:key="swipeDuration"
        app:max="@integer/max_action_gesture_swipe_duration"
        app:min="0"
        app:step="10"
        app:units="ms"
        app:updatesContinuously="false"/>
    <com.quickcursor.android.preferences.TickSeekBarPreference
        android:title="@string/action_gesture_multi_touch_title"
        android:summary="@string/action_gesture_multi_touch_description"
        app:defaultValue="1"
        app:iconSpaceReserved="false"
        app:key="multiTouch"
        app:tickTexts="@array/actions_multi_touch_ticks"
        app:ticksStartFromZero="false"/>
</PreferenceScreen>
