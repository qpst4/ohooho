<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingBottom="12dp"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/colorPrimary"
        app:cardCornerRadius="4dp"
        app:contentPadding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_weight="0"
                    android:contentDescription="@string/buy_pro_description_title"
                    app:srcCompat="@drawable/icon_premium"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/buy_pro_description_title"
                    android:layout_weight="1"
                    android:fontFamily="@font/hkgrotesk"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <ScrollView
                android:id="@+id/stepsScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:id="@+id/proFeaturesDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/buy_pro_features_description"/>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardView">
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@+id/floatingBuyLifetime"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scaleType="center"
            android:text="@string/buy_quick_cursor_pro_lifetime"
            android:textAllCaps="false"
            android:fontFamily="@font/hkgrotesk"
            android:backgroundTint="@color/colorAccent"
            app:fabSize="normal"
            app:icon="@drawable/icon_buy_lifetime"
            app:iconTint="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Widget.MaterialComponents.ExtendedFloatingActionButton.Icon.QuickCursor"/>
        <TextView
            android:gravity="center"
            android:id="@+id/textViewOr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/buy_pro_or"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/floatingBuyLifetime"/>
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@+id/floatingBuySubscription"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scaleType="center"
            android:text="@string/buy_quick_cursor_pro_subscription"
            android:textAllCaps="false"
            android:fontFamily="@font/hkgrotesk"
            android:backgroundTint="@color/colorAccent"
            app:fabSize="normal"
            app:icon="@drawable/icon_subscription"
            app:iconTint="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textViewOr"
            style="@style/Widget.MaterialComponents.ExtendedFloatingActionButton.Icon.QuickCursor"/>
        <TextView
            android:gravity="center"
            android:id="@+id/textViewFreeTrial"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/buy_pro_subscription_30_days_trial"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/floatingBuySubscription"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
