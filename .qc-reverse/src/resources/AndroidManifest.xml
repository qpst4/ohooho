            android:name="com.quickcursor.android.activities.settings.CursorSettings"
            android:parentActivityName="com.quickcursor.android.activities.SettingsActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.settings.TrackerSettings"
            android:parentActivityName="com.quickcursor.android.activities.SettingsActivity"/>
