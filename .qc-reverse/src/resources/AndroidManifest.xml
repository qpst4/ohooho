        android:label="@string/app_name"
        android:icon="@mipmap/launcher_icon"
        android:name="com.quickcursor.App"
        android:description="@string/app_name"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:extractNativeLibs="false"
        android:roundIcon="@mipmap/launcher_icon_round"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory">
        <property
            android:name="android.window.PROPERTY_COMPAT_ALLOW_RESTRICTED_RESIZABILITY"
            android:value="true"/>
        <activity
            android:name="com.quickcursor.android.activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity
            android:theme="@style/Theme.AppCompat.Translucent"
            android:name="com.quickcursor.android.activities.ShortcutActivity"
            android:exported="true"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.CREATE_SHORTCUT"/>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        <activity
            android:name="com.quickcursor.android.activities.AboutActivity"
            android:parentActivityName="com.quickcursor.android.activities.MainActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.OpenSourceActivity"
            android:parentActivityName="com.quickcursor.android.activities.AboutActivity"/>
