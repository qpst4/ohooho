        <activity
            android:name="com.quickcursor.android.activities.settings.TrackerActionsSettings"
            android:configChanges="fontScale|layoutDirection|density|smallestScreenSize|screenSize|uiMode|screenLayout|orientation|navigation|keyboardHidden|keyboard|touchscreen|locale"
            android:parentActivityName="com.quickcursor.android.activities.SettingsActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.settings.VibrationsAndVisualSettings"
            android:parentActivityName="com.quickcursor.android.activities.SettingsActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.settings.BlacklistSettings"
            android:parentActivityName="com.quickcursor.android.activities.SettingsActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.settings.BackupAndRestoreSettings"
            android:parentActivityName="com.quickcursor.android.activities.SettingsActivity"/>
