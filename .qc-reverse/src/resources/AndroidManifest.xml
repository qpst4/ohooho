            android:name="com.quickcursor.android.activities.SettingsActivity"
            android:parentActivityName="com.quickcursor.android.activities.MainActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.HowToUseActivity"
            android:parentActivityName="com.quickcursor.android.activities.MainActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.BatteryOptimizationsActivity"
            android:parentActivityName="com.quickcursor.android.activities.MainActivity"/>
        <activity
            android:name="com.quickcursor.android.activities.settings.TriggersSettings"
