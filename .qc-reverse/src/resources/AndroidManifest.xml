            android:name="com.quickcursor.android.services.CursorAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:description="@string/accessibility_service_description">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/cursor_accessibility_service"/>
        </service>
        <service
            android:label="@string/app_name"
            android:icon="@drawable/icon_quick_settings_tile"
            android:name="com.quickcursor.android.services.QuickSettingsTileService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE"/>
            </intent-filter>
